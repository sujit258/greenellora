# Managed cloud database (MongoDB Atlas example)
MONGODB_URI=mongodb+srv://<username>:Password@<cluster>/<database>?retryWrites=true&w=majority

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=greenellora

# Admin authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=use-a-strong-password
JWT_SECRET=4669cffc5c9261ff46eb13fbca9192c27cc2bad543f89d630910ad5a85fa3801287a43a8a87bfc471ff77c855791af10e962093350224a2e2acf21163524bb82

# Optional email notifications
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@greenellora.com
SMTP_FROM_NAME=Green Ellora
QUOTE_TO_EMAIL=hello@greenellora.com

# WhatsApp number that receives click-to-chat enquiries. Include country code, no +, spaces, or dashes.
WHATSAPP_BUSINESS_NUMBER=919876543210
